# ⚠️ 将此文件复制为 .env 并填入真实值，.env 已被 gitignore 不会提交
# cp .env.example .env

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ox
PG_SCHEMA=root
PG_USER=postgres
PG_PASSWORD=your_password_here

# Milvus
MILVUS_URI=http://your_host:19530
MILVUS_TOKEN=root:your_token
MILVUS_COLLECTION=local_document_vectors

# DashScope
DASHSCOPE_API_KEY=sk-your_api_key_here
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024

# Redis
REDIS_HOST=your_host
REDIS_PORT=6379
REDIS_PASSWORD=your_password_here
REDIS_DB=1

# LangSmith / OpenTelemetry
OTEL_SERVICE_NAME=rag-system
LANGCHAIN_API_KEY=lsv2_your_key_here
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com/otel/v1/traces
LANGCHAIN_PROJECT=rag-system

# Memory
SESSION_MEMORY_TOKEN_LIMIT=4096
USER_MEMORY_TOKEN_LIMIT=100000
MEMORY_VECTOR_TOP_K=3
MILVUS_MEMORY_COLLECTION=local_rag_user_memory
MEMORY_DEFAULT_USER_ID=admin
